---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Home">
  <div class="header-container">
    <div class="title-section">
      <h1>José Luiz Nunes</h1>
      <p class="lead">PhD Candidate, Department of Informatics — PUC‑Rio · Researcher, Center for Technology and Society — FGV Direito Rio</p>
    </div>
    <div class="profile-image">
      <img src="/images/pic.jpg" alt="Profile picture" />
    </div>
  </div>

  <h2>About Me</h2>
  <p>
    I am an academic researcher interested in interdisciplinary work in Human-Centered Computing,
    especially at the intersection of machine learning and ethics, machine behavior, and quantitative
    empirical legal studies.
  </p>
  <p>
    Currently, I am a PhD Candidate in the Department of Informatics at the Pontifical Catholic
    University of Rio de Janeiro (PUC-Rio). I also conduct research at the Center for Technology and
    Society at FGV Direito Rio.
  </p>

  <p>
    You can view my <a href="/publications/">Publications</a>, course materials, and download my <a href="/cv/">CV</a>.
  </p>

  <h2>Research Interests</h2>
  <ul>
    <li>Ethics of machine learning</li>
    <li>Machine psychology and AI models behaviour</li>
    <li>Empirical legal studies and precedent analysis</li>
    <li>Moral evaluation of LLMs</li>
  </ul>

  <h2>Teaching</h2>
  <p>I teach undergraduate courses at FGV Direito Rio:</p>
  <ul>
    <li>Programming for Lawyers</li>
    <li>Legal Data Science</li>
  </ul>

  <h2>Contact</h2>
  <ul>
    <li>Email: jose.luiz at fgv.br OR jnunes at inf.puc-rio.br</li>
    <li>Social: <a href="https://bsky.app/profile/joseluiz.bsky.social">Bluesky</a></li>
  </ul>
</BaseLayout>
