---
const currentPath = Astro.url.pathname;

const navLinks = [
  { text: 'Home', href: '/' },
  { text: 'Publications', href: '/publications/' },
  { text: 'Courses', href: '/courses/' },
];

const socialLinks = [
  {
    href: 'https://bsky.app/profile/joseluiz.bsky.social',
    label: 'Bluesky',
    icon: 'bluesky',
  },
  {
    href: 'https://www.researchgate.net/profile/Jose-Luiz-Nunes',
    label: 'ResearchGate',
    icon: 'researchgate',
  },
  {
    href: 'https://www.linkedin.com/in/jos%C3%A9-luiz-nunes-7b77b412a/',
    label: 'LinkedIn',
    icon: 'linkedin',
  },
  {
    href: 'https://github.com/joseluizn',
    label: 'GitHub',
    icon: 'github',
  },
];
---

<nav class="navbar">
  <div class="nav-left">
    {navLinks.map((link) => (
      <a href={link.href} class:list={[{ active: currentPath === link.href }]}>
        {link.text}
      </a>
    ))}
  </div>
  <div class="nav-right">
    {socialLinks.map((link) => (
      <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label}>
        {link.icon === 'bluesky' && (
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565C.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479c.815 2.736 3.713 3.66 6.383 3.364c.136-.02.275-.039.415-.056c-.138.022-.276.04-.415.056c-3.912.58-7.387 2.005-2.845 7.082c5.008 4.408 6.725 1.083 7.838-1.18c1.113 2.263 2.83 5.588 7.838 1.18c4.542-5.077 1.067-6.502-2.845-7.082a13.88 13.88 0 0 1-.415-.056c.14.017.279.036.415.056c2.67.296 5.568-.628 6.383-3.364c.246-.828.624-5.79.624-6.479c0-.688-.139-1.86-.902-2.203c-.659-.3-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8"/></svg>
        )}
        {link.icon === 'researchgate' && (
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d="M19.586 0c-1.9 0-3.298 1.564-3.298 3.474c0 1.252.58 2.192 1.476 2.763l-.29.447c-.353.563-.831.867-1.344.867c-.626 0-.982-.376-1.022-.961h-.023c0-.7-.544-1.168-1.168-1.168c-.7 0-1.168.544-1.168 1.168c0 1.597 1.168 2.818 3.088 2.818c1.246 0 2.296-.627 3.012-1.78l.453-.715c.393.174.85.266 1.343.266c2.167 0 3.355-1.564 3.355-3.474C23 1.564 21.753 0 19.586 0zM4.414 9.274c-2.356 0-4.414 2.127-4.414 5.09c0 3.049 2.09 5.09 4.627 5.09c1.174 0 2.18-.51 2.923-1.392l.123.032c-.027.32-.044.65-.044.987c0 2.738 1.18 4.919 3.705 4.919c2.465 0 3.666-2.035 3.666-4.345c0-.477-.04-.907-.108-1.296l-.023-.003c-.062.33-.27.561-.588.561c-.35 0-.573-.32-.573-.81v-.006c0-1.722-.473-3.156-1.327-4.187c-.87-1.049-2.156-1.7-3.781-1.7c-.768 0-1.5.18-2.139.508c-.135-.535-.32-.96-.55-1.265c-.354-.47-.827-.713-1.383-.713c-.674 0-1.114.462-1.114 1.06c0 .573.41 1.06 1.114 1.06c.281 0 .52-.095.714-.262c.148.467.223 1.06.223 1.779v.04c-.663-.376-1.424-.59-2.247-.59l-.003-.001zm0 1.823c1.482 0 2.521 1.324 2.521 3.267c0 1.943-1.039 3.267-2.52 3.267c-1.427 0-2.467-1.324-2.467-3.267c0-1.943 1.04-3.267 2.466-3.267z"/></svg>
        )}
        {link.icon === 'linkedin' && (
          <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248c-.015-.709-.52-1.248-1.342-1.248c-.822 0-1.359.54-1.359 1.248c0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586c.173-.431.568-.878 1.232-.878c.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252c-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/></svg>
        )}
        {link.icon === 'github' && (
          <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59c.4.07.55-.17.55-.38c0-.19-.01-.82-.01-1.49c-2.01.37-2.53-.49-2.69-.94c-.09-.23-.48-.94-.82-1.13c-.28-.15-.68-.52-.01-.53c.63-.01 1.08.58 1.23.82c.72 1.21 1.87.87 2.33.66c.07-.52.28-.87.51-1.07c-1.78-.2-3.64-.89-3.64-3.95c0-.87.31-1.59.82-2.15c-.08-.2-.36-1.02.08-2.12c0 0 .67-.21 2.2.82c.64-.18 1.32-.27 2-.27c.68 0 1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82c.44 1.1.16 1.92.08 2.12c.51.56.82 1.27.82 2.15c0 3.07-1.87 3.75-3.65 3.95c.29.25.54.73.54 1.48c0 1.07-.01 1.93-.01 2.2c0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
        )}
      </a>
    ))}
  </div>
</nav>

<style>
  .active {
    font-weight: 500;
    border-bottom: 2px solid #fff;
  }
</style>
